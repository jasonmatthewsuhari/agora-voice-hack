[node name="TheoryText" type="RichTextLabel" parent="JournalShell/Margin/Book/LeftPage/TheoryPanel/TheoryPadding/TheoryBody"]
custom_minimum_size = Vector2(0, 176)
layout_mode = 2
size_flags_vertical = 3
bbcode_enabled = true
scroll_active = false
text = "[i]The killer knew the manor layout and moved during blackout. The crash in the atrium and the missing candlestick feel connected.[/i]\n\n[b]Current read:[/b] Someone is staging panic to hide a planned route between the kitchen corridor and the conservatory."

